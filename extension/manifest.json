{
  "manifest_version": 3,
  "name": "AI Document Processing",
  "version": "1.0.0",
  "description": "Extract structured data from unstructured documents using AWS AI services",
  "permissions": [
    "storage",
    "tabs",
    "downloads",
    "clipboardWrite",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open AI Document Processing"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
